# PVE 节点地址（必填）
PVE_HOST=https://192.168.1.100:8006

# API Token 认证（推荐）
# 在 PVE Web UI → Datacenter → Permissions → API Tokens 创建
# 权限建议：Sys.Audit, VM.Audit, VM.Monitor, Datastore.Audit
PVE_TOKEN_ID=monitor@pam!mcp-token
PVE_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SSL 证书验证（PVE 自签名证书时设为 false）
PVE_VERIFY_SSL=false

# API 请求超时（秒）
PVE_TIMEOUT=10

# 节点名称（留空则自动检测，单机模式可不填）
PVE_NODE_NAME=

# 日志级别：DEBUG / INFO / WARNING / ERROR
PVE_LOG_LEVEL=INFO
